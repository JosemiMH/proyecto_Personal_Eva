# Copy this file to .env for local development only. Never commit real values.

# Database Configuration
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# OpenAI API (for chatbot functionality)
OPENAI_API_KEY=replace-with-openai-api-key

# Email Configuration
EMAIL_USER=epm@epmwellness.com
EMAIL_PASS=replace-with-smtp-password
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_FROM="Eva Pérez - EPM Wellness <epm@epmwellness.com>"

# Environment
NODE_ENV=production
PORT=3000

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-64-character-value
